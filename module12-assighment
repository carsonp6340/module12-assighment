# 2.2 Create a stacked bar chart showing the composition of sales in each location
# REQUIRED: Function must create and return a matplotlib figure
def plot_sales_composition_by_location():
   
    location_category_sales = sales_df.groupby(['Location', 'Category'])['Sales'].sum().unstack()
    
    location_category_percent = (location_category_sales.T / location_category_sales.sum(axis=1)).T * 100


    fig, ax = plt.subplots(figsize=(8, 5))
    location_category_percent.plot(kind='bar', stacked=True, ax=ax, colormap='tab20')

    
    ax.set_title('Sales Composition by Location (Percentage Breakdown)')
    ax.set_xlabel('Location')
    ax.set_ylabel('Percentage of Total Sales (%)')
    ax.legend(title='Category', loc='upper left')
    ax.grid(axis='y', linestyle='--', alpha=0.7)

    return fig

